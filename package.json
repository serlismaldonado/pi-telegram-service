{
  "name": "pi-telegram-service",
  "version": "1.0.1",
  "description": "24/7 Telegram bot powered by the Pi coding agent SDK — per-user sessions, persistent memory, multi-LLM support",
  "type": "module",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/serlismaldonado/pi-telegram-service"
  },
  "keywords": [
    "telegram",
    "bot",
    "pi",
    "pi-agent",
    "llm",
    "minimax",
    "anthropic",
    "ai"
  ],
  "author": "serlismaldonado",
  "license": "MIT",
  "files": [
    "dist/",
    "src/",
    ".env.example",
    "ecosystem.config.cjs",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "logs": "pm2 logs pi-telegram",
    "status": "pm2 status",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "latest",
    "@mariozechner/pi-coding-agent": "latest",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.4.5",
    "node-telegram-bot-api": "^0.66.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
